{
    "title": "Google Play Store Reviews Scraper",
    "description": "Extract reviews from Google Play using an app URL or package ID.",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "url": {
            "title": "App URL or package ID",
            "type": "string",
            "description": "Google Play app URL or package ID. Example: https://play.google.com/store/apps/details?id=com.linkedin.android",
            "editor": "textfield",
            "prefill": "https://play.google.com/store/apps/details?id=com.linkedin.android&hl=en&gl=US"
        },
        "results_wanted": {
            "title": "Results wanted",
            "type": "integer",
            "description": "Maximum number of reviews to collect.",
            "minimum": 1,
            "default": 20,
            "prefill": 20,
            "editor": "number"
        },
        "max_pages": {
            "title": "Maximum pages",
            "type": "integer",
            "description": "Safety cap on API pages.",
            "minimum": 1,
            "default": 10,
            "prefill": 10,
            "editor": "number"
        },
        "sort": {
            "title": "Sort reviews",
            "type": "string",
            "description": "Review order.",
            "default": "newest",
            "prefill": "newest",
            "enum": [
                "newest",
                "helpfulness",
                "rating"
            ],
            "enumTitles": [
                "Newest",
                "Most helpful",
                "By rating"
            ],
            "editor": "select"
        },
        "lang": {
            "title": "Language",
            "type": "string",
            "description": "Play Store language code.",
            "default": "en",
            "prefill": "en",
            "editor": "textfield"
        },
        "country": {
            "title": "Country",
            "type": "string",
            "description": "Play Store country code.",
            "default": "us",
            "prefill": "us",
            "editor": "textfield"
        },
        "proxyConfiguration": {
            "title": "Proxy configuration",
            "type": "object",
            "description": "Use Apify Proxy for higher reliability at scale.",
            "editor": "proxy",
            "default": {
                "useApifyProxy": false
            }
        }
    },
    "required": [],
    "additionalProperties": false
}
